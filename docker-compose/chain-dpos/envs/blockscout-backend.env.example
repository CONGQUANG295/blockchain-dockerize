# Generated by render-envs.sh from deploy.env — copy for manual setup only
# Synced structure from explorer server (secrets redacted)
SECRET_KEY_BASE=
DATABASE_URL=postgresql://blockscout:CHANGE_ME@db:5432/blockscout?sslmode=disable
ETHEREUM_JSONRPC_VARIANT=nethermind
BLOCK_TRANSFORMER=base
ETHEREUM_JSONRPC_HTTP_URL=http://rpc.host:8545/
ETHEREUM_JSONRPC_TRACE_URL=http://rpc.host:8545/
ETHEREUM_JSONRPC_WS_URL=ws://rpc.host:8546/
CHAIN_ID=4599
COIN=GTBS
COIN_NAME=GTBS
DISABLE_MARKET=true
# Indexer / DB pool — tune for archive RPC + catch-up indexing
POOL_SIZE=80
POOL_SIZE_API=20
INDEXER_DISABLE_INTERNAL_TRANSACTIONS_FETCHER=true
INDEXER_DISABLE_PENDING_TRANSACTIONS_FETCHER=true
INDEXER_RECEIPTS_CONCURRENCY=5
INDEXER_CATCHUP_BLOCKS_CONCURRENCY=5
# GTBS profile (EXPLORER_CUSTOM_PROFILE=gtbs)
TOKEN_ICON_CHAIN_SLUG=gtbs
TOKEN_ICON_ASSETS_BASE_URL=https://raw.githubusercontent.com/gtbschain/assets/master/blockchains
# Account / Auth0 (optional — set ACCOUNT_ENABLED=false to disable)
# Auth0 setup for email OTP login: ../../../docs/explorer-auth0-login.md
ACCOUNT_ENABLED=true
ACCOUNT_CLOAK_KEY=
ACCOUNT_AUTH0_DOMAIN=your-tenant.us.auth0.com
ACCOUNT_AUTH0_CLIENT_ID=
ACCOUNT_AUTH0_CLIENT_SECRET=
RE_CAPTCHA_SECRET_KEY=
ACCOUNT_REDIS_URL=redis://redis-db:6379
BLOCKSCOUT_HOST=gtbsblockchain.com
BLOCKSCOUT_PROTOCOL=https
# Backend API and DB always use 0x addresses; do not add display-prefix vars here.
