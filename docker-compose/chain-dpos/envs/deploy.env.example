# Master deploy config for chain-dpos (copy → deploy.env, then ./scripts/render-envs.sh)
# Required chain identity — no defaults for new chain
NETWORK_NAME=DPOS-Testnet
NETWORK_ID=0x3a1
NETWORK_TYPE=testnet
BLOCK_TIME_SECONDS=5
CONTRACT_TRANSITION_BLOCK=100
PREMINE_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
PREMINE_BALANCE_WEI=300000000000000000000000000
VALIDATOR_BALANCE_WEI=10000000000000000000000
# INITIAL_SUPPLY_GWEI is derived by render-envs.sh: PREMINE_BALANCE_WEI / 1e9

# GTBS tokenomics (required when ENABLE_CUSTOM_STAKING=true)
# PREMINE_BALANCE_WEI=1500000000000000000000000000
# MAX_SUPPLY_WEI=3000000000000000000000000000
# BLOCK_TIME_SECONDS=3   → BLOCKS_PER_YEAR derived as 31536000 / BLOCK_TIME_SECONDS

# EIP-1559 (London) — optional; rendered into envs/dpos.chain.env by render-envs.sh
# Without EIP-1559 (default): deploy uses gasPrice=0 — no gas fee spent
# With ENABLE_EIP1559=true: set VALIDATOR_BALANCE_WEI large enough for deploy gas
# ENABLE_EIP1559=true
# EIP1559_TRANSITION_BLOCK=250
# EIP1559_BASE_FEE_INITIAL_VALUE=0xE8D4A51000
# EIP1559_BASE_FEE_MAX_CHANGE_DENOMINATOR=0x8
# EIP1559_ELASTICITY_MULTIPLIER=0x2
# EIP1559_BASE_FEE_MIN_VALUE=0xE8D4A51000
# EIP1559_FEE_COLLECTOR=0x0000000000000000000000000000000000000000

# Opt-in GTBS custom staking (Consensus + BlockReward + StakingVault)
ENABLE_CUSTOM_STAKING=false

# Contract economics (dpos.contract.env)
DECIMALS=18
MIN_STAKE_TOKENS=100000
MAX_STAKE_TOKENS=25000000
DEFAULT_VALIDATOR_FEE_PERCENT=15
CYCLE_DURATION_SECONDS=172800
INFLATION_PERCENT=5

# Docker Hub — set namespace to pull pre-built images from CI
# Images resolve to: ${DOCKERHUB_NAMESPACE}/blockchain-dock-<name>:<version>
# Leave unset for local dev (uses local tags like openethereum:0.0.1)
DOCKERHUB_NAMESPACE=your-dockerhub-username

# Remote deploy — SSH hosts (Makefile: cờ EXPLORER=1 | SEED=1 | DAPPS=1 hoặc SERVER=)
# REMOTE_DEPLOY_DIR=/opt/blockchain-dock
# SEED_SERVER=root@91.229.245.75       # Server 1 — validator seed
# EXPLORER_SERVER=root@203.0.113.60   # Server 3 — Blockscout + RPC archive
# DAPPS_SERVER=root@203.0.113.70      # Server DApps — netstats, docs, faucet

# P2P cross-server peering (RPC / new validators pull genesis/reserved-peers.txt)
# OPEN_P2P_PORT=true          # ufw allow 30300 TCP/UDP on deploy/provision
# P2P_PUBLIC_IP=91.229.245.75  # enode IP in reserved-peers (auto-detect if unset)
# P2P_PORT=30300
# SSH_PORT=22                 # ufw allow SSH before P2P (auto-detect from sshd_config if unset)

# Optional: override individual images (full ref including registry/tag)
# OPENETHEREUM_IMAGE=
# VALIDATOR_APP_IMAGE=
# DPOS_DEPLOYER_IMAGE=
# BLOCKSCOUT_BACKEND_IMAGE=
# BLOCKSCOUT_FRONTEND_IMAGE=
# BLOCKSCOUT_STATS_IMAGE=ghcr.io/blockscout/stats:latest
# BLOCKSCOUT_VISUALIZER_IMAGE=ghcr.io/blockscout/visualizer:latest
# NETSTATS_API_IMAGE=
# NETSTATS_DASHBOARD_IMAGE=
# ETH_FAUCET_IMAGE=
# DOCS_IMAGE=

# Secrets — set explicitly before first explorer deploy (render copies into db.env / blockscout-*.env)
# Generate: openssl rand -hex 32  (POSTGRES_PASSWORD, STATS_DB_PASSWORD)
#           openssl rand -hex 64  (SECRET_KEY_BASE)
POSTGRES_PASSWORD=
POSTGRES_DB=blockscout
STATS_DB_PASSWORD=
SECRET_KEY_BASE=
# Netstats: same secret on DApps (netstats-dashboard) and every validator (netstats-api)
# Generate: openssl rand -hex 32
WS_SECRET=
# Netstats dashboard branding (rendered into netstats-dashboard.env)
# PAGE_TITLE defaults to "${COIN_NAME} Network Status"
# FAVICON_URL defaults to "${EXPLORER_ASSETS_BASE_URL}/symbol.svg"
# NETSTATS_PAGE_TITLE=
# NETSTATS_FAVICON_URL=

# Network display (explorer frontend)
COIN_NAME=Coin
COIN_SYMBOL=COIN
NEXT_PUBLIC_IS_TESTNET=true

# Custom address display (explorer UI only — chain/backend keep 0x)
# Empty ADDRESS_DISPLAY_PREFIX = feature off (standard 0x explorer)
# UI shows BIP-173 bech32: {prefix}1{data} e.g. custom1qxy2kg... — NOT custom1 + 40 hex chars
ADDRESS_DISPLAY_PREFIX=custom1
ADDRESS_DISPLAY_DEFAULT=bech32
ADDRESS_FORMAT_TOGGLE=true

# Optional explorer custom profile (see docs/explorer-custom-theme.md)
# EXPLORER_CUSTOM_PROFILE=gtbs
# EXPLORER_HERO_TITLE=GTBS Blockchain Explorer
# Explorer branding assets (raw GitHub — no volume mount)
EXPLORER_ASSETS_BASE_URL=https://raw.githubusercontent.com/gtbschain/assets/master/explorer

# Traefik / domains (required with --with-traefik)
ACME_EMAIL=admin@example.com
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_DASHBOARD_HOST=traefik.example.com
RPC_SERVER_NAME=testnet-rpc.example.com
EXPLORER_SERVER_NAME=explorer.example.com
STATS_SERVER_NAME=stats.example.com
VISUALIZE_SERVER_NAME=visualize.example.com
STATUS_SERVER_NAME=status.example.com
FAUCET_SERVER_NAME=faucet.example.com
DOCS_SERVER_NAME=docs.example.com
