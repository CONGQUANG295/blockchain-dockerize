# GTBS explorer profile — merged into blockscout-frontend.env when EXPLORER_CUSTOM_PROFILE=gtbs
# Set CONSENSUS_ADDRESS from contract-addresses.json after deploy

NEXT_PUBLIC_CONSENSUS_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BLOCK_TIME_SECONDS=5
NEXT_PUBLIC_NETWORK_RPC_URL=http://rpc.host:8545/
NEXT_PUBLIC_HOMEPAGE_HERO_TITLE=GTBS Blockchain Explorer
NEXT_PUBLIC_HOMEPAGE_HERO_BANNER_CONFIG='{"background":["linear-gradient(90deg, #FFC107 0%, #1A1B23 65%)"],"text_color":["#FFFFFF"],"button":{"_default":{"background":["#FFC107"],"text_color":["#000000"]}}}'
NEXT_PUBLIC_COLOR_THEME_DEFAULT=dark
NEXT_PUBLIC_COLOR_THEME_OVERRIDES='{"button":{"primary":{"_dark":{"value":"#FFC107"}}}}'
NEXT_PUBLIC_FOOTER_PROJECT_CONFIG='{"title":"Powered by GTBS","taglineUrl":"https://gtbs.org","description":"Block Explorer and Analytics platform for GTBS Ecosystem.","copyright":"GTBS © 2024 | Built by GTBS Team"}'
NEXT_PUBLIC_FOOTER_LINKS=file:///assets/configs/footer-links.json
NEXT_PUBLIC_NETWORK_LOGO=file:///assets/configs/network-logo.svg
NEXT_PUBLIC_NETWORK_ICON=file:///assets/configs/network-icon.svg
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false
NEXT_PUBLIC_DPOS_GAUGE_COLOR=#FFC107
