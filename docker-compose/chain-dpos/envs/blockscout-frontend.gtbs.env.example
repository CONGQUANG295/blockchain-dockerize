# GTBS explorer profile — merged into blockscout-frontend.env when EXPLORER_CUSTOM_PROFILE=gtbs
# Base API/network vars are generated by render-envs.sh from deploy.env
# Address display: set ADDRESS_DISPLAY_* in deploy.env — render-envs.sh injects NEXT_PUBLIC_VIEWS_ADDRESS_*
# CONSENSUS_ADDRESS is injected from genesis/contract-addresses.json when available

# App
NEXT_PUBLIC_APP_INSTANCE=local
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_USE_NEXT_JS_PROXY=false

# Network
NEXT_PUBLIC_NETWORK_TOKEN_STANDARD_NAME=${COIN_SYMBOL}
NEXT_PUBLIC_NETWORK_VERIFICATION_TYPE=validation
NEXT_PUBLIC_NETWORK_RPC_URL=https://${RPC_SERVER_NAME}

# Logo (raw GitHub — set EXPLORER_ASSETS_BASE_URL in deploy.env)
NEXT_PUBLIC_NETWORK_LOGO=${EXPLORER_ASSETS_BASE_URL}/network_logo.png
NEXT_PUBLIC_NETWORK_LOGO_DARK=${EXPLORER_ASSETS_BASE_URL}/network_logo_dark.png
NEXT_PUBLIC_NETWORK_ICON=${EXPLORER_ASSETS_BASE_URL}/network_icon.svg
NEXT_PUBLIC_NETWORK_ICON_DARK=${EXPLORER_ASSETS_BASE_URL}/network_icon_dark.svg
NEXT_PUBLIC_FEATURED_NETWORKS=${EXPLORER_ASSETS_BASE_URL}/featured_networks.json
NEXT_PUBLIC_PROMOTE_BLOCKSCOUT_IN_TITLE=false

# Theme & homepage (HERO_TITLE from render-envs.sh when EXPLORER_HERO_TITLE is set)
NEXT_PUBLIC_HOMEPAGE_HERO_BANNER_CONFIG='{"background":["linear-gradient(90deg, #FFC107 0%, #1A1B23 65%)"],"text_color":["#FFFFFF"],"button":{"_default":{"background":["#FFC107"],"text_color":["#000000"]}}}'
NEXT_PUBLIC_COLOR_THEME_DEFAULT=dark
NEXT_PUBLIC_COLOR_THEME_OVERRIDES='{"button":{"primary":{"_dark":{"value":"#FFC107"}}}}'
NEXT_PUBLIC_DPOS_GAUGE_COLOR=#FFC107

# Web3
NEXT_PUBLIC_WEB3_DISABLE_ADD_TOKEN_TO_WALLET=false
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Ads (disabled)
NEXT_PUBLIC_AD_BANNER_PROVIDER=none
NEXT_PUBLIC_AD_TEXT_PROVIDER=none

# Account / auth (disabled)
NEXT_PUBLIC_IS_ACCOUNT_SUPPORTED=false

# Marketplace & DeFi (disabled)
NEXT_PUBLIC_MARKETPLACE_ENABLED=false
NEXT_PUBLIC_DEFI_DROPDOWN_ITEMS=[]

# Footer
NEXT_PUBLIC_FOOTER_PROJECT_CONFIG='{"title":"Powered by GTBS","taglineUrl":"https://gtbs.org","description":"Block Explorer and Analytics platform for GTBS Ecosystem.","copyright":"GTBS 2025 | Built by GTBS Team"}'

# DPoS widgets
NEXT_PUBLIC_CONSENSUS_ADDRESS=${CONSENSUS_PROXY}
NEXT_PUBLIC_STAKING_VAULT_ADDRESS=${STAKING_VAULT_PROXY}

# Backend service proxies
NEXT_PUBLIC_ADMIN_SERVICE_API_HOST=https://${EXPLORER_SERVER_NAME}
NEXT_PUBLIC_METADATA_SERVICE_API_HOST=https://${EXPLORER_SERVER_NAME}
NEXT_PUBLIC_CONTRACT_INFO_API_HOST=https://${EXPLORER_SERVER_NAME}

# Network explorers
NEXT_PUBLIC_NETWORK_EXPLORERS="[{'title':'${NETWORK_NAME}','baseUrl':'https://${EXPLORER_SERVER_NAME}','paths':{'tx':'/tx','address':'/address'}}]"
