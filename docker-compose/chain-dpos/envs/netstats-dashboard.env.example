# Must match WS_SECRET in deploy.env and netstats-api.env on every validator
WS_SECRET=${WS_SECRET}
WS_HOST=host.docker.internal
PORT=3006
# Rendered from deploy.env: PAGE_TITLE=${COIN_NAME} Network Status
PAGE_TITLE=${COIN_NAME} Network Status
# Rendered from deploy.env: FAVICON_URL=${EXPLORER_ASSETS_BASE_URL}/symbol.svg
FAVICON_URL=${EXPLORER_ASSETS_BASE_URL}/symbol.svg
