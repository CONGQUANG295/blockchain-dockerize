# Required — no defaults for a new chain deployment
NETWORK_NAME=DPOS-Testnet
NETWORK_ID=0x3a1
NETWORK_TYPE=testnet
BLOCK_TIME_SECONDS=5
CONTRACT_TRANSITION_BLOCK=100

# Treasury premine (must differ from auto-generated VALIDATOR_1_ADDRESS)
PREMINE_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
PREMINE_BALANCE_WEI=300000000000000000000000000
# Gas for validator-1 genesis balance (account must exist in spec.json)
# Without EIP-1559 (default): deploy uses gasPrice=0 — no gas fee spent
# With ENABLE_EIP1559=true: must be large enough to pay deploy gas (recommend >= 10 ETH)
VALIDATOR_BALANCE_WEI=10000000000000000000000
INITIAL_SUPPLY_GWEI=300000000

# EIP-1559 (London) — optional; disabled by default for backward compatibility
# ENABLE_EIP1559=true
# EIP1559_TRANSITION_BLOCK=200   # > CONTRACT_TRANSITION_BLOCK → deploy vẫn zero-gas
# EIP1559_BASE_FEE_INITIAL_VALUE=0x3B9ACA00
# EIP1559_BASE_FEE_MAX_CHANGE_DENOMINATOR=0x8
# EIP1559_ELASTICITY_MULTIPLIER=0x2
# EIP1559_BASE_FEE_MIN_VALUE=0x1DCD6500
# EIP1559_FEE_COLLECTOR=0x0000000000000000000000000000000000000000

# Restore example default after local smoke testing:
# CONTRACT_TRANSITION_BLOCK=100
# BLOCK_TIME_SECONDS=5
