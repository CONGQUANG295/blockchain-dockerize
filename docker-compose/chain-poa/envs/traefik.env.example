# Traefik / proxy environment (reference).
# Copy: cp envs/traefik.env.example envs/traefik.env

# --- ACME / Traefik core ---
ACME_EMAIL=admin@example.com
TRAEFIK_LOG_LEVEL=INFO

# Traefik dashboard (optional)
TRAEFIK_DASHBOARD_ENABLED=true
TRAEFIK_DASHBOARD_HOST=traefik.example.com

# mainnet | testnet
NETWORK_TYPE=mainnet

# --- RPC (Geth JSON-RPC / WebSocket) ---
RPC_SERVER_NAME=mainnet-rpc.example.com
# RPC_ENABLE=true

# --- Blockscout v4 (single backend on :4000) ---
BLOCKSCOUT_BACK_SERVER_NAME=explorer.example.com
# BLOCKSCOUT_V4_ENABLE=true

# --- Blockscout v5 (frontend :5004 + backend :4000) ---
BLOCKSCOUT_FRONT_SERVER_NAME=explorer.example.com
# BLOCKSCOUT_V5_ENABLE=true

# --- Netstats dashboard ---
STATUS_SERVER_NAME=status.example.com

# --- Eth faucet (testnet) ---
FAUCET_SERVER_NAME=faucet.example.com

# --- Docs (static site) ---
DOCS_SERVER_NAME=docs.example.com

# --- Blockscout v5 extras ---
STATS_SERVER_NAME=stats.example.com
VISUALIZE_SERVER_NAME=visualize.example.com
