map $http_upgrade $connection_upgrade {
  default upgrade;
  ''      close;
}

server {
  listen 80;

  server_name ${BLOCKSCOUT_FRONT_SERVER_NAME} www.${BLOCKSCOUT_FRONT_SERVER_NAME};
  proxy_http_version 1.1;
  access_log /var/log/nginx/${NETWORK_TYPE}-explorer.access.log;

  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    proxy_pass            ${BLOCKSCOUT_FRONT_PROXY_PASS};
    proxy_http_version    1.1;
    proxy_set_header      Host "$host";
    proxy_set_header      X-Real-IP "$remote_addr";
    proxy_set_header      X-Forwarded-For "$proxy_add_x_forwarded_for";
    proxy_set_header      X-Forwarded-Proto "$scheme";
    proxy_set_header      Upgrade "$http_upgrade";
    proxy_set_header      Connection $connection_upgrade;
    proxy_cache_bypass    $http_upgrade;
  }

  location = / {
    proxy_pass ${BLOCKSCOUT_BACK_PROXY_PASS};
    proxy_http_version 1.1;
    proxy_redirect off;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header Host $host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
  }

  location ~ ^/(css|js) {
    proxy_pass            ${BLOCKSCOUT_FRONT_PROXY_PASS};
    proxy_http_version    1.1;
    proxy_set_header      Host "$host";
    proxy_set_header      X-Real-IP "$remote_addr";
    proxy_set_header      X-Forwarded-For "$proxy_add_x_forwarded_for";
    proxy_set_header      X-Forwarded-Proto "$scheme";
    proxy_set_header      Upgrade "$http_upgrade";
    proxy_set_header      Connection $connection_upgrade;
    proxy_cache_bypass    $http_upgrade;
  }

  location ~ ^/(_next|node-api|apps|account|accounts|static|auth/profile|auth/unverified-email|txs|tx|blocks|block|login|address|stats|search-results|token|tokens|visualize|api-docs|csv-export|verified-contracts|graphiql|withdrawals|favicon|assets) {
    proxy_pass            ${BLOCKSCOUT_BACK_PROXY_PASS};
    proxy_http_version    1.1;
    proxy_set_header      Host "$host";
    proxy_set_header      X-Real-IP "$remote_addr";
    proxy_set_header      X-Forwarded-For "$proxy_add_x_forwarded_for";
    proxy_set_header      X-Forwarded-Proto "$scheme";
    proxy_set_header      Upgrade "$http_upgrade";
    proxy_set_header      Connection $connection_upgrade;
    proxy_cache_bypass    $http_upgrade;
  }
    
  location ~^/metrics {
    return 403;
  }

  error_page 403 /custom_403.html;
  location = /custom_403.html {
    root /usr/share/nginx/html;
    internal;
  }
 
  error_page 502 /custom_502.html;
  location = /custom_502.html {
    root /usr/share/nginx/html;
    internal;
  }
}