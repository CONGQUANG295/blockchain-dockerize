map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
  listen 80;
  server_name ${STATUS_SERVER_NAME} www.${STATUS_SERVER_NAME};
  access_log /var/log/nginx/${NETWORK_TYPE}-status.access.log;

  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    return 301 https://${STATUS_SERVER_NAME}$request_uri;
  }
}

server {
  listen 443 ssl;
  server_name ${STATUS_SERVER_NAME} www.${STATUS_SERVER_NAME};
  access_log /var/log/nginx/${NETWORK_TYPE}-stats.access.log;

  ssl_certificate /etc/nginx/ssl/live/${STATUS_SERVER_NAME}/fullchain.pem; # managed by Certbot
  ssl_certificate_key /etc/nginx/ssl/live/${STATUS_SERVER_NAME}/privkey.pem; # managed by Certbot
  include /etc/nginx/ssl/options-ssl-nginx.conf; # managed by Certbot
  ssl_dhparam /etc/nginx/ssl/ssl-dhparams.pem; # managed by Certbot

  location / {
    proxy_pass            ${STATUS_PROXY_PASS};
    proxy_http_version    1.1;
    proxy_set_header      Host "$host";
    proxy_set_header      X-Real-IP "$remote_addr";
    proxy_set_header      X-Forwarded-For "$proxy_add_x_forwarded_for";
    proxy_set_header      X-Forwarded-Proto "$scheme";
    proxy_set_header      Upgrade "$http_upgrade";
    proxy_set_header      Connection $connection_upgrade;
    proxy_cache_bypass    $http_upgrade;
  }
}